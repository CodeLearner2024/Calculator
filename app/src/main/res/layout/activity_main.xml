<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp">

    <!-- Écran affichage -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="end|bottom"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bordure_ecran">

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="20sp"
            android:textColor="#888888"
            android:gravity="end"/>

        <EditText
            android:id="@+id/tvResultat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="48sp"
            android:textColor="#1A1A1A"
            android:gravity="end"
            android:background="@null"
            android:inputType="none"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:cursorVisible="true"/>

    </LinearLayout>

    <!-- Ligne C / +- / ( / ) / / -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">
        <Button android:id="@+id/btnClear"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="C"
            android:layout_margin="3dp"
            android:textColor="#A32D2D"
            android:backgroundTint="#FCEBEB"/>
        <Button android:id="@+id/btn_vide1"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="+/-"
            android:layout_margin="3dp"
            android:textColor="#185FA5"
            android:backgroundTint="#E6F1FB"/>
        <Button android:id="@+id/btnParenOuv"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="("
            android:layout_margin="3dp"
            android:textColor="#185FA5"
            android:backgroundTint="#E6F1FB"/>
        <Button android:id="@+id/btnParenFerm"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text=")"
            android:layout_margin="3dp"
            android:textColor="#185FA5"
            android:backgroundTint="#E6F1FB"/>
        <Button android:id="@+id/btnDiv"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="/"
            android:layout_margin="3dp"
            android:textColor="#185FA5"
            android:backgroundTint="#E6F1FB"/>
    </LinearLayout>

    <!-- Ligne 7 8 9 * -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">
        <Button android:id="@+id/btn7"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="7"
            android:layout_margin="3dp"
            android:textColor="#1A1A1A"
            android:backgroundTint="#F5F5F5"/>
        <Button android:id="@+id/btn8"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="8"
            android:layout_margin="3dp"
            android:textColor="#1A1A1A"
            android:backgroundTint="#F5F5F5"/>
        <Button android:id="@+id/btn9"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="9"
            android:layout_margin="3dp"
            android:textColor="#1A1A1A"
            android:backgroundTint="#F5F5F5"/>
        <Button android:id="@+id/btnMul"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="*"
            android:layout_margin="3dp"
            android:textColor="#185FA5"
            android:backgroundTint="#E6F1FB"/>
    </LinearLayout>

    <!-- Ligne 4 5 6 - -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">
        <Button android:id="@+id/btn4"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="4"
            android:layout_margin="3dp"
            android:textColor="#1A1A1A"
            android:backgroundTint="#F5F5F5"/>
        <Button android:id="@+id/btn5"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="5"
            android:layout_margin="3dp"
            android:textColor="#1A1A1A"
            android:backgroundTint="#F5F5F5"/>
        <Button android:id="@+id/btn6"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="6"
            android:layout_margin="3dp"
            android:textColor="#1A1A1A"
            android:backgroundTint="#F5F5F5"/>
        <Button android:id="@+id/btnSub"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="-"
            android:layout_margin="3dp"
            android:textColor="#185FA5"
            android:backgroundTint="#E6F1FB"/>
    </LinearLayout>

    <!-- Ligne 1 2 3 + -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">
        <Button android:id="@+id/btn1"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="1"
            android:layout_margin="3dp"
            android:textColor="#1A1A1A"
            android:backgroundTint="#F5F5F5"/>
        <Button android:id="@+id/btn2"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="2"
            android:layout_margin="3dp"
            android:textColor="#1A1A1A"
            android:backgroundTint="#F5F5F5"/>
        <Button android:id="@+id/btn3"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="3"
            android:layout_margin="3dp"
            android:textColor="#1A1A1A"
            android:backgroundTint="#F5F5F5"/>
        <Button android:id="@+id/btnAdd"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="+"
            android:layout_margin="3dp"
            android:textColor="#185FA5"
            android:backgroundTint="#E6F1FB"/>
    </LinearLayout>

    <!-- Ligne 0 . ⌫ = -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">
        <Button android:id="@+id/btn0"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="0"
            android:layout_margin="3dp"
            android:textColor="#1A1A1A"
            android:backgroundTint="#F5F5F5"/>
        <Button android:id="@+id/btnDot"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="."
            android:layout_margin="3dp"
            android:textColor="#1A1A1A"
            android:backgroundTint="#F5F5F5"/>
        <Button android:id="@+id/btnBack"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="⌫"
            android:layout_margin="3dp"
            android:textColor="#A32D2D"
            android:backgroundTint="#FCEBEB"/>
        <Button android:id="@+id/btnEqual"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="match_parent" android:text="="
            android:layout_margin="3dp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#185FA5"/>
    </LinearLayout>

</LinearLayout>